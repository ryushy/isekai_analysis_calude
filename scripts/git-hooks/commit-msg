#!/bin/sh
# CVE-0 commit-msg（事前フック）：日本語コミット規約のプレフィックスを強制
#   feat: / fix: / docs: / refactor: / test: / chore: / style: / perf:
# Merge / Revert コミットは許可。

msg_file="$1"
first="$(head -n 1 "$msg_file")"

case "$first" in
  feat:*|fix:*|docs:*|refactor:*|test:*|chore:*|style:*|perf:*) ;;
  Merge\ *|Revert\ *|"fixup! "*|"squash! "*) ;;
  *)
    echo "✗ commit-msg: コミットメッセージの先頭にプレフィックスを付けてください。" >&2
    echo "   使えるプレフィックス: feat: fix: docs: refactor: test: chore: style: perf:" >&2
    echo "   例: feat: 戦闘システムに飛躍条件を追加" >&2
    exit 1
    ;;
esac

exit 0
